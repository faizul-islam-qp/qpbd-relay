# =====================
# Database
# =====================
DATABASE_URL=postgresql://wick:wick@localhost:5432/wick_office

# =====================
# JWT
# =====================
JWT_SECRET=change-me-use-a-long-random-string-here
JWT_EXPIRES_IN=7d

# =====================
# VAPID (Web Push)
# Generate: npx web-push generate-vapid-keys
# =====================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# =====================
# Telegram Bot
# Get token from @BotFather on Telegram
# Optional — OTP falls back to console log if not set
# =====================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=   # e.g. qpbd_office_bot (without @) — shown on login page even if bot can't connect

# =====================
# Admin seed (created on first boot)
# =====================
ADMIN_EMAIL=admin@questionpro.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Admin

# =====================
# CORS / Server
# =====================
CORS_ORIGINS=http://localhost:3000
PORT=3001
NODE_ENV=development

# =====================
# Frontend (for production Docker build)
# =====================
VITE_API_URL=https://your-api-domain.com
VAPID_PUBLIC_KEY=  # same as above, passed as build arg
